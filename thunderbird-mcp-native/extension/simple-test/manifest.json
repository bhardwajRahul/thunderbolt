{
  "manifest_version": 2,
  "name": "Thunderbird MCP Test",
  "version": "1.0.4",
  "description": "Simple test extension",
  
  "applications": {
    "gecko": {
      "id": "thunderbird-mcp-test@example.com",
      "strict_min_version": "78.0"
    }
  },
  
  "permissions": [
    "storage"
  ],
  
  "background": {
    "scripts": ["simple-background.js"],
    "persistent": false
  },
  
  "browser_action": {
    "default_title": "MCP Test",
    "default_popup": "simple-popup.html",
    "default_icon": {
      "32": "icons/icon-32.png"
    }
  },
  
  "icons": {
    "32": "icons/icon-32.png"
  }
}