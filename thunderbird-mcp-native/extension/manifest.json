{
  "manifest_version": 3,
  "name": "Thunderbird MCP Server",
  "version": "1.0.5",
  "description": "Model Context Protocol server for Thunderbird data access",
  "author": "Your Name",
  
  "browser_specific_settings": {
    "gecko": {
      "id": "thunderbird-mcp@example.com",
      "strict_min_version": "128.0"
    }
  },
  
  "permissions": [
    "addressBooks",
    "accountsRead",
    "messagesRead",
    "storage",
    "nativeMessaging",
    "tabs"
  ],
  
  "background": {
    "scripts": ["background/background.js"]
  },
  
  "action": {
    "default_title": "Thunderbird MCP Server",
    "default_popup": "popup/index.html",
    "default_icon": "icons/icon-32.png",
    "default_area": "maintoolbar",
    "allowed_spaces": ["mail", "addressbook", "calendar", "tasks", "chat"]
  },
  
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}